From a5ac5f1e065ccaf09ae7f9c11e925ccf818339d5 Mon Sep 17 00:00:00 2001
From: Will Dietz <will.dietz@sifive.com>
Date: Tue, 16 Jan 2024 07:27:14 -0600
Subject: [PATCH] don't fetch fmt.

Use the fmt checkout symlinked into external/fmt by slang.nix instead of
letting FetchContent reach the network. Deliberately not satisfied with
nixpkgs' fmt via FIND_PACKAGE_ARGS: a found system fmt makes slang's
generated slangConfig.cmake emit find_dependency(fmt), which would push
a new configure-time dependency onto every consumer (i.e. CIRCT).
---
 external/CMakeLists.txt | 11 ++---------
 1 file changed, 2 insertions(+), 9 deletions(-)

diff --git a/external/CMakeLists.txt b/external/CMakeLists.txt
index 512ae5c..905e761 100644
--- a/external/CMakeLists.txt
+++ b/external/CMakeLists.txt
@@ -8,19 +8,12 @@ set(FMT_SYSTEM_HEADERS
     ON
     CACHE INTERNAL "")

-FetchContent_Declare(
-  fmt
-  GIT_REPOSITORY https://github.com/fmtlib/fmt.git
-  GIT_TAG 12.1.0
-  GIT_SHALLOW ON
-  FIND_PACKAGE_ARGS 12.1)
-
 # Force fmtlib to always be a static lib if we pull it via FetchContent (i.e.
 # not intercepted by find_package), since it's a private dependency that's
 # mostly header-only already.
 set(saved_build_shared_libs ${BUILD_SHARED_LIBS})
 set(BUILD_SHARED_LIBS OFF)
-FetchContent_MakeAvailable(fmt)
+add_subdirectory(external/fmt)
 set(BUILD_SHARED_LIBS ${saved_build_shared_libs})

 if((SLANG_INCLUDE_PYLIB OR BUILD_SHARED_LIBS) AND NOT fmt_FOUND)
@@ -192,7 +185,7 @@ if(SLANG_INCLUDE_INSTALL)
       PUBLIC_HEADER EXCLUDE_FROM_ALL
       PRIVATE_HEADER EXCLUDE_FROM_ALL)
     install(
-      DIRECTORY ${fmt_SOURCE_DIR}/include/fmt
+      DIRECTORY external/fmt/include/fmt
       DESTINATION ${CMAKE_INSTALL_INCLUDEDIR}
       COMPONENT slang_Development)
   endif()
